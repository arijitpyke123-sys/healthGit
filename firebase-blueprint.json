{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile for patients and doctors.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["doctor", "patient"] },
        "name": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "maxLength": 100 },
        "dob": { "type": "string", "maxLength": 20 },
        "specialty": { "type": "string", "maxLength": 100 },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "locationName": { "type": "string", "maxLength": 255 },
        "userId": { "type": "string", "maxLength": 128 }
      },
      "required": ["role", "name", "email", "userId"]
    },
    "Branch": {
      "title": "Diagnosis Branch",
      "description": "A branch created by a doctor for a patient.",
      "type": "object",
      "properties": {
        "doctorId": { "type": "string", "maxLength": 128 },
        "patientId": { "type": "string", "maxLength": 128 },
        "name": { "type": "string", "maxLength": 100 },
        "status": { "type": "string", "enum": ["active", "merged"] },
        "createdAt": { "type": "number" },
        "branchId": { "type": "string", "maxLength": 128 }
      },
      "required": ["doctorId", "patientId", "name", "status", "createdAt", "branchId"]
    },
    "Commit": {
      "title": "Diagnosis Commit",
      "description": "A commit in a branch.",
      "type": "object",
      "properties": {
        "hash": { "type": "string", "maxLength": 128 },
        "branchId": { "type": "string", "maxLength": 128 },
        "message": { "type": "string", "maxLength": 1000 },
        "clinicalData": { "type": "string", "maxLength": 10000 },
        "authorId": { "type": "string", "maxLength": 128 },
        "authorName": { "type": "string", "maxLength": 100 },
        "timestamp": { "type": "number" }
      },
      "required": ["hash", "branchId", "message", "clinicalData", "authorId", "authorName", "timestamp"]
    },
    "MainCommit": {
      "title": "Patient Main Commit",
      "description": "A commit merged into the patient's main branch.",
      "type": "object",
      "properties": {
        "hash": { "type": "string", "maxLength": 128 },
        "patientId": { "type": "string", "maxLength": 128 },
        "message": { "type": "string", "maxLength": 1000 },
        "clinicalData": { "type": "string", "maxLength": 10000 },
        "authorId": { "type": "string", "maxLength": 128 },
        "authorName": { "type": "string", "maxLength": 100 },
        "timestamp": { "type": "number" },
        "isMerge": { "type": "boolean" },
        "mergedFromBranchId": { "type": "string", "maxLength": 128 }
      },
      "required": ["hash", "patientId", "message", "clinicalData", "authorId", "authorName", "timestamp", "isMerge"]
    },
    "Booking": {
      "title": "Doctor Appointment Booking",
      "description": "A booking made by a patient for a doctor.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string", "maxLength": 128 },
        "patientId": { "type": "string", "maxLength": 128 },
        "patientName": { "type": "string", "maxLength": 100 },
        "doctorId": { "type": "string", "maxLength": 128 },
        "doctorName": { "type": "string", "maxLength": 100 },
        "doctorAddress": { "type": "string", "maxLength": 255 },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "appointmentTime": { "type": "string", "maxLength": 50 },
        "timestamp": { "type": "number" }
      },
      "required": ["bookingId", "patientId", "patientName", "doctorName", "status", "appointmentTime", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Stores appointment bookings."
    },
    "/branches/{branchId}": {
      "schema": { "$ref": "#/entities/Branch" },
      "description": "Stores doctor branches for patients."
    },
    "/branches/{branchId}/commits/{commitId}": {
      "schema": { "$ref": "#/entities/Commit" },
      "description": "Stores commits belonging to a branch."
    },
    "/patient_commits/{patientId}/commits/{commitId}": {
      "schema": { "$ref": "#/entities/MainCommit" },
      "description": "Stores the main timeline commits for a patient."
    }
  }
}
